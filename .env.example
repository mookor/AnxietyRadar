# Адрес и порт HTTP API
# API_BIND_HOST — на каком интерфейсе слушает сервер (0.0.0.0 = доступен в локальной сети)
API_BIND_HOST=0.0.0.0
API_PORT=8000

# API_CLIENT_HOST — адрес для клиентов на этом же ПК (overlay, test_api)
# Для WEMOS/телефона в сети используйте LAN IP компьютера, например 192.168.0.141
API_CLIENT_HOST=localhost

# Зона поиска самолётов: lat1, lon1, lat2, lon2
BOUNDS_LAT1=55.049295
BOUNDS_LON1=82.695093
BOUNDS_LAT2=54.972320
BOUNDS_LON2=82.992117

# Максимальная высота самолёта (метры)
MAX_ALTITUDE_M=20000

# Учитывать самолёты на земле
INCLUDE_GROUND=true

# Интервал опроса FlightRadar (секунды)
FINDER_POLL_INTERVAL_S=1

# Удалять самолёт из списка, если не видели N секунд
PLANE_STALE_SECONDS=60

# Удалять самолёты ниже этой высоты (метры)
MIN_ALTITUDE_M=10

# Интервал опроса API для overlay-индикатора (миллисекунды)
OVERLAY_POLL_INTERVAL_MS=1500

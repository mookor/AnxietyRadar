# .env для клиента (overlay.py / tkinter на вашем ПК)
# Скопируйте в корень репозитория: copy .env.client.example .env

# Публичный IP или домен сервера, где крутится find_planes.py
API_CLIENT_HOST=your-server.example.com
API_PORT=8001

# На клиенте не используется сервером, но нужен config.py:
API_BIND_HOST=127.0.0.1

# Зона поиска — на клиенте не влияет на overlay (только опрос API)
BOUNDS_LAT1=55.040451
BOUNDS_LON1=82.537111
BOUNDS_LAT2=54.972320
BOUNDS_LON2=82.992117

MAX_ALTITUDE_M=20000
INCLUDE_GROUND=true
FINDER_POLL_INTERVAL_S=1
PLANE_STALE_SECONDS=60
MIN_ALTITUDE_M=10

# Как часто overlay опрашивает /planes/count (мс)
OVERLAY_POLL_INTERVAL_MS=1500
